# Cloudflare Turnstile Challenge Configuration
#
# To get your Turnstile keys:
# 1. Go to https://dash.cloudflare.com/
# 2. In the left sidebar, find "Turnstile" under "AI & ML"
# 3. Click "Create site"
# 4. Enter a name (e.g., "Setup Terminal")
# 5. Choose Challenge Type: "Managed Challenge" (recommended)
# 6. Add Allowed Domains: your domain (e.g., setup.example.com)
# 7. Click Create
# 8. Copy the "Site Key" and paste below as TURNSTILE_SITE_KEY
# 9. Copy the "Secret Key" and paste below as TURNSTILE_SECRET_KEY
#
# For testing/development, you can use Cloudflare's test keys:
#   Site Key:    1x00000000000000000000AA
#   Secret Key:  1x0000000000000000000000000000000AA
#
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# COOKIE_SECRET is auto-generated during installation by terminal.sh module hook.
# It does not need to be filled manually.
COOKIE_SECRET=

# WeTTY Configuration
TERMINAL_MAX_CLIENTS=5
SESSION_TIMEOUT_SECONDS=1800
