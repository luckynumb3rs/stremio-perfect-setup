UPSTREAM_REPO=https://github.com/Viren070/docker-compose-template.git
UPSTREAM_REF=main
TEMPLATE_SOURCE=upstream
WORK_ROOT=.work
TEMPLATE_DIR=${WORK_ROOT}/docker
CONFIG_DIR=${WORK_ROOT}/config
BACKUP_OUTPUT_DIR=${HOME}
BACKUP_BASENAME=streaming
DOCKER_TARGET_DIR=/opt/docker
DEFAULT_TIMEZONE=Europe/Berlin
DEFAULT_SSH_ALIAS=streaming
DEFAULT_SSH_KEY_NAME=streaming
DEFAULT_EXISTING_SSH_KEYS=id_ed25519,ed25519,id_rsa
REQUIRED_PROFILE=required
