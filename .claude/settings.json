{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Agent",
      "Task",
      "TaskCreate",
      "TaskUpdate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "NotebookEdit",
      "Monitor",
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree",
      "ExitWorktree",
      "CronCreate",
      "CronDelete",
      "CronList",
      "RemoteTrigger",
      "PushNotification",
      "ScheduleWakeup",
      "mcp__ide__getDiagnostics",
      "mcp__ide__executeCode"
    ],
    "defaultMode": "plan"
  },
  "model": "opusplan",
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "theme": "dark"
}
