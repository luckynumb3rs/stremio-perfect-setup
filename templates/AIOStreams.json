          { "value": "bs", "label": "🇧🇦 Bosnian" },
          { "value": "bg", "label": "🇧🇬 Bulgarian" },
          { "value": "ca", "label": "🇪🇸 Catalan" },
          { "value": "zh", "label": "🇨🇳 Chinese" },
          { "value": "ze", "label": "🇨🇳 Chinese (Bilingual)" },
          { "value": "zt", "label": "🇹🇼 Chinese (Traditional)" },
          { "value": "hr", "label": "🇭🇷 Croatian" },
          { "value": "cs", "label": "🇨🇿 Czech" },
          { "value": "da", "label": "🇩🇰 Danish" },
          { "value": "nl", "label": "🇳🇱 Dutch" },
          { "value": "en", "label": "🇬🇧 English" },
          { "value": "et", "label": "🇪🇪 Estonian" },
          { "value": "fi", "label": "🇫🇮 Finnish" },
          { "value": "fr", "label": "🇫🇷 French" },
          { "value": "ka", "label": "🇬🇪 Georgian" },
          { "value": "de", "label": "🇩🇪 German" },
          { "value": "el", "label": "🇬🇷 Greek" },
          { "value": "he", "label": "🇮🇱 Hebrew" },
          { "value": "hi", "label": "🇮🇳 Hindi" },
          { "value": "hu", "label": "🇭🇺 Hungarian" },
          { "value": "is", "label": "🇮🇸 Icelandic" },
          { "value": "id", "label": "🇮🇩 Indonesian" },
          { "value": "it", "label": "🇮🇹 Italian" },
          { "value": "ja", "label": "🇯🇵 Japanese" },
          { "value": "kk", "label": "🇰🇿 Kazakh" },
          { "value": "ko", "label": "🇰🇷 Korean" },
          { "value": "lv", "label": "🇱🇻 Latvian" },
          { "value": "lt", "label": "🇱🇹 Lithuanian" },
          { "value": "mk", "label": "🇲🇰 Macedonian" },
          { "value": "ms", "label": "🇲🇾 Malay" },
          { "value": "mn", "label": "🇲🇳 Mongolian" },
          { "value": "nb", "label": "🇳🇴 Norwegian (Bokmål)" },
          { "value": "nn", "label": "🇳🇴 Norwegian (Nynorsk)" },
          { "value": "no", "label": "🇳🇴 Norwegian" },
          { "value": "fa", "label": "🇮🇷 Persian" },
          { "value": "pl", "label": "🇵🇱 Polish" },
          { "value": "pt", "label": "🇵🇹 Portuguese" },
          { "value": "pb", "label": "🇧🇷 Portuguese (Brazil)" },
          { "value": "ro", "label": "🇷🇴 Romanian" },
          { "value": "ru", "label": "🇷🇺 Russian" },
          { "value": "sr", "label": "🇷🇸 Serbian" },
          { "value": "sk", "label": "🇸🇰 Slovak" },
          { "value": "sl", "label": "🇸🇮 Slovenian" },
          { "value": "es", "label": "🇪🇸 Spanish" },
          { "value": "sv", "label": "🇸🇪 Swedish" },
          { "value": "th", "label": "🇹🇭 Thai" },
          { "value": "tr", "label": "🇹🇷 Turkish" },
          { "value": "uk", "label": "🇺🇦 Ukrainian" },
          { "value": "vi", "label": "🇻🇳 Vietnamese" }
        ]
      },
      {
        "id": "header.addons",
        "name": "🧩 Addon Options",
        "description": "",
        "type": "alert",
        "intent": "info"
      },
      {
        "__if": "services",
        "id": "anime",
        "name": "🗡️ Anime Addons",
        "description": "If enabled, additional anime-specific addons (**SeaDex, AnimeTosho**) will be installed.",
        "type": "boolean",
        "required": false,
        "default": false
      },
      {
        "__if": "services",
        "id": "debridio",
        "name": "🧊 Debridio",
        "description": "If enabled, [Debridio Scraper](https://debridio.com) will be added. You will need your *Debridio API key* from your account settings. Leave it disabled if you don't know what this is.",
        "type": "boolean",
        "required": false,
        "default": false
      },
      {
        "id": "httpAddons",
        "name": "🌐 HTTP Addons",
        "description": "If enabled, addons for **HTTP** streams will be included. Good backup options for niche/older titles, or if you don't/can't use debrid and/or torrents, but you can enable this even if you do use them if you want extra results. These addons rely on hoster scrapers and generally have less reliable sources, so they are disabled by default to avoid cluttering the stream list with low-quality sources for users who prefer debrid and/or P2P options.",
        "type": "boolean",
        "required": false,
        "default": false
      },
      {
        "id": "timeout",
        "name": "⏱️ Global Timeout",
        "description": "Enter the time in ms that you're willing to wait for results before your scraper addons timeout. You can set it a bit higher if you have issues getting enough results or you want to make sure to get as many results as possible.",
        "type": "number",
        "required": false,
        "default": 5000
      },
      {
        "id": "header.sorting",
        "name": "↕️ Sorting Options",
        "description": "",
        "type": "alert",
        "intent": "info"
      },
      {
        "id": "header.sortingInfo",
        "name": "",
        "description": "Here you can modify the sort order if necessary. \n The default sort order is: \n *Cached/Uncached → SeaDex (for Anime) → Resolution → Quality → Stream Expressions → Stream Expression Score → Seeders (if Uncached/P2P) → Language → Bitrate*",
        "type": "alert",
        "intent": "info-basic"
      },
      {
        "id": "language",
        "name": "🚩️ Language Priority",
        "description": "This option can give priority to streams in your preferred languages by moving it up the sorting order. If you struggle to see your preferred languages in the results, even after adding it to the **Preferred Languages** list, try increasing the priority here. May rank lower-quality streams higher if your preferred languages are uncommon among the results, so use with caution.",
        "type": "select",
        "required": false,
        "default": "default",
        "options": [
          {
            "value": "default",
            "label": "Default Sort Order"
          },
          {
            "value": "medium",
            "label": "Move Up After Resolution & Quality"
          },
          {
            "value": "high",
            "label": "Move Up First in Sort Order"
          }
        ]
      },
      {
        "__if": "!services",
        "id": "seeders",
        "name": "🌱 Seeders Priority",
        "description": "Change this if you want highest seeders to be prioritized more on the sorting order, even if they have lower Resolution/Quality/SEL Scores. In most cases, low seeders will have already been filtered out by the internal filtering (SEL).",
        "type": "select",
        "required": false,
        "default": "default",
        "options": [
          {
            "value": "default",
            "label": "Default Sort Order"
          },
          {
            "value": "medium",
            "label": "Move Up After Resolution & Quality"
          },
          {
            "value": "high",
            "label": "Move Up First in Sort Order"
          }
        ]
      },
      {
        "id": "credits",
        "name": "Credits",
        "description": "",
        "type": "socials",
        "socials": [
          {
            "id": "website",
            "url": "https://luckynumb3rs.github.io/stremio-perfect-setup"
          },
          {
            "id": "github",
            "url": "https://github.com/luckynumb3rs/stremio-perfect-setup"
          },
          {
            "id": "ko-fi",
            "url": "https://ko-fi.com/luckynumb3rs"
          }
        ]
      }
	  ]
  },
  "config": {
    "addonName": "AIOStreams",
    "serviceWrap": {
      "__if": "services",
      "__value": {
        "enabled": true
      }
    },
    "services": [
      {
        "id": "torbox",
        "enabled": false,
        "credentials": {}
      }
    ],
    "presets": [
      {
        "__if": "inputs.anime",
        "type": "seadex",
        "instanceId": "sdx",
        "enabled": true,
        "options": {
          "name": "SeaDex",
          "timeout": "{{inputs.timeout}}",
          "mediaTypes": [
            "anime"
          ]
        }
      },
      {
        "__if": "services",
        "type": "library",
        "instanceId": "lib",
        "enabled": true,
        "options": {
          "name": "Library",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "mediaTypes": [],
          "showRefreshActions": [
            "catalog"
          ],
          "skipProcessing": false,
          "hideStreams": false,
          "useMultipleInstances": false
        }
      },
      {
        "__if": "services.torbox",
        "type": "torbox",
        "instanceId": "tbx",
        "enabled": true,
        "options": {
          "name": "TorBox",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "mediaTypes": []
        }
      },
      {
        "__if": "inputs.debridio",
        "type": "debridio",
        "instanceId": "deb",
        "enabled": true,
        "options": {
          "name": "Debridio",
          "timeout": "{{inputs.timeout}}",
          "debridioApiKey": "<template_placeholder>"
        }
      },
      {
        "type": "torrentio",
        "instanceId": "tio",
        "enabled": true,
        "options": {
          "name": "Torrentio",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "providers": [],
          "useMultipleInstances": false
        }
      },
      {
        "type": "meteor",
        "instanceId": "met",
        "enabled": true,
        "options": {
          "name": "Meteor",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "includeP2P": {
            "__switch": "services",
            "cases": {
              "": true
            },
            "default": false
          },
          "removeTrash": false,
          "useMultipleInstances": false,
          "mediaTypes": []
        }
      },
      {
        "type": "comet",
        "instanceId": "com",
        "enabled": true,
        "options": {
          "name": "Comet",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "includeP2P": {
            "__switch": "services",
            "cases": {
              "": true
            },
            "default": false
          },
          "removeTrash": false,
          "mediaTypes": []
        }
      },
      {
        "type": "stremthruTorz",
        "instanceId": "stz",
        "enabled": true,
        "options": {
          "name": "StremThru Torz",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "includeP2P": {
            "__switch": "services",
            "cases": {
              "": true
            },
            "default": false
          },
          "useMultipleInstances": false,
          "mediaTypes": []
        }
      },
      {
        "type": "mediafusion",
        "instanceId": "mdf",
        "enabled": true,
        "options": {
          "name": "MediaFusion",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "useCachedResultsOnly": true,
          "enableWatchlistCatalogs": false,
          "downloadViaBrowser": false,
          "contributorStreams": false,
          "certificationLevelsFilter": [],
          "nudityFilter": [],
          "mediaTypes": []
        }
      },
      {
        "__if": "services",
        "type": "knaben",
        "instanceId": "kna",
        "enabled": true,
        "options": {
          "name": "Knaben",
          "timeout": "{{inputs.timeout}}",
          "mediaTypes": [],
          "useMultipleInstances": false
        }
      },
      {
        "type": "peerflix",
        "instanceId": "pfl",
        "enabled": true,
        "options": {
          "name": "Peerflix",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "mediaTypes": [],
          "useMultipleInstances": false,
          "showTorrentLinks": {
            "__switch": "services",
            "cases": {
              "": true
            },
            "default": false
          }
        }
      },
      {
        "__if": "inputs.anime",
        "type": "animetosho",
        "instanceId": "ato",
        "enabled": true,
        "options": {
          "name": "AnimeTosho",
          "timeout": "{{inputs.timeout}}",
          "mediaTypes": [
            "anime"
          ],
          "useMultipleInstances": false
        }
      },
      {
        "__if": "inputs.httpAddons",
        "type": "sootio",
        "instanceId": "soo",
        "enabled": true,
        "options": {
          "name": "Sootio",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "httpProviders": [
            "http4khdhub",
            "httpHDHub4u",
            "httpUHDMovies",
            "httpMoviesDrive",
            "httpMKVCinemas",
            "httpMkvDrama",
            "httpMalluMv",
            "httpCineDoze",
            "httpNetflixMirror",
            "httpVixSrc"
          ],
          "mediaTypes": [],
          "useMultipleInstances": false
        }
      },
      {
        "__if": "inputs.httpAddons and inputs.debridio",
        "type": "debridio-watchtower",
        "instanceId": "dew",
        "enabled": true,
        "options": {
          "name": "Watchtower",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "debridioApiKey": "<template_placeholder>",
          "mediaTypes": []
        }
      },
      {
        "__if": "inputs.httpAddons",
        "type": "nuvio-streams",
        "instanceId": "nuv",
        "enabled": true,
        "options": {
          "name": "Nuvio Streams",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "showBoxRegion": "USA7",
          "providers": [],
          "mediaTypes": []
        }
      },
      {
        "__if": "inputs.httpAddons",
        "type": "webstreamr",
        "instanceId": "wst",
        "enabled": true,
        "options": {
          "name": "WebStreamr",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "mediaTypes": [],
          "providers": [
            "multi",
            "en",
            "de",
            "es",
            "fr",
            "hi",
            "it",
            "mx"
          ],
          "includeExternalUrls": false,
          "showErrors": false
        }
      },
      {
        "type": "subhero",
        "instanceId": "sbh",
        "enabled": true,
        "options": {
          "name": "SubHero",
          "timeout": 15000,
          "resources": [
            "subtitles"
          ],
          "languages": [
            "{{inputs.subtitles}}"
          ]
        }
      }
    ],
    "formatter": {
      "__switch": "inputs.formatterChoice",
      "cases": {
        "flat": {
          "id": "custom",
          "definition": {
            "name": "{service.cached::istrue[\"⚡ \"||\"\"]}{service.cached::isfalse[\"⏳ \"||\"\"]}{stream.type::=p2p[\"🧲 \"||\"\"]}{stream.type::=http[\"🌐 \"||\"\"]}{stream.type::=live[\"📺 \"||\"\"]}{stream.type::=youtube[\"▶️ \"||\"\"]}{stream.type::=archive[\"🗄️ \"||\"\"]}{stream.type::=external[\"↗️ \"||\"\"]}{stream.type::=statistic[\"📊 \"||\"\"]}{stream.type::=info[\"ℹ️ \"||\"\"]}{stream.type::=error[\"⛔ \"||\"\"]}{stream.resolution::exists[\"{stream.resolution::replace('2160p','UHD ⁴ᴷ')::replace('1440p','QHD ²ᴷ')::replace('1080p','FHD    ')::replace('p','P')}   \"||\"\"]}\n{stream.quality::exists[\"⌜{stream.quality::title::replace('Bluray Remux','Remux')::smallcaps}⌟    \"||\"\"]}\n{stream.nSeScore::>=10[\"{stream.nSeScore::pstar::replace('★','◆')::replace('⯪','⬖')::replace('☆','◇')} \"||\"\"]}",
