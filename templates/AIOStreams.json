  "config": {
    "addonName": "AIOStreams",
    "presets": {
      "__switch": "services",
      "cases": {
        "": [
          {
            "type": "torrentio",
            "instanceId": "4ef",
            "enabled": true,
            "options": {
              "name": "Torrentio",
              "timeout": "{{inputs.timeout}}",
              "resources": [
                "stream"
              ],
              "providers": [],
              "useMultipleInstances": false
            }
          },
          {
            "type": "meteor",
            "instanceId": "064",
            "enabled": true,
            "options": {
              "name": "Meteor",
              "timeout": "{{inputs.timeout}}",
              "resources": [
                "stream"
              ],
              "includeP2P": true,
              "removeTrash": false,
              "useMultipleInstances": false,
              "mediaTypes": []
            }
          },
          {
            "type": "comet",
            "instanceId": "b0f",
            "enabled": true,
