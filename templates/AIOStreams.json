      {
        "id": "languagesRequired",
        "name": "🔒 Show Only Preferred Languages",
        "description": "If enabled (recommended), only streams in the selected languages above will be shown (including *Original, Dual Audio, Multi, Dubbed, and Unknown*). This can help reduce clutter by filtering out streams in languages you don't prefer.",
        "type": "boolean",
        "required": false,
        "default": true
      },
      {
        "id": "subtitles",
        "name": "💬 Preferred Subtitles",
        "description": "Select the subtitles that should be loaded when opening a stream. Change them in **Addons → SubHero** after import if you want.",
        "type": "multi-select",
        "required": false,
        "default": [
          "en"
        ],
        "options": [
          { "value": "sq", "label": "🇦🇱 Albanian" },
          { "value": "ar", "label": "🇸🇦 Arabic" },
          { "value": "hy", "label": "🇦🇲 Armenian" },
