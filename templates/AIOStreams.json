      {
        "id": "header.addons",
        "name": "🧩 Addon Options",
        "description": "",
        "type": "alert",
        "intent": "info"
      },
      {
        "__if": "services",
        "id": "anime",
        "name": "🗡️ Anime Addons",
        "description": "If enabled, additional anime-specific addons (**SeaDex, AnimeTosho**) will be installed.",
        "type": "boolean",
        "required": false,
        "default": false
      },
      {
        "__if": "services",
        "id": "debridio",
        "name": "🧊 Debridio",
        "description": "If enabled, [Debridio Scraper](https://debridio.com) will be added. You will need your *Debridio API key* from your account settings. Leave it disabled if you don't know what this is.",
        "type": "boolean",
        "required": false,
        "default": false
      },
      {
        "id": "httpAddons",
        "name": "🌐 HTTP Addons",
        "description": "Select if you want addons for **HTTP** streams to be installed. These addons rely on free online hosters and generally have less reliable sources and speeds, but can be good backup options if you don't or can't use Debrid and/or P2P. You can select: \n* **None** to not include any HTTP addons at all. \n* **Install Additional HTTP Addons** to install them in addition to the Debrid/P2P addons. \n* **Install Only HTTP Addons** to not include any Debrid/P2P addons and only use HTTP addons, if P2P is an issue for you or you can't/don't use Debrid (*do not select this option if you are using a Debrid*).",
        "type": "select",
        "required": false,
        "default": "none",
        "options": [
          {
            "value": "none",
            "label": "🚫 No HTTP Addons"
          },
          {
            "value": "install",
            "label": "➕ Install Additional HTTP Addons"
          },
          {
            "value": "only",
            "label": "🔒 Install Only HTTP Addons (Don't select with Debrid)"
          }
        ]
      },
      {
        "id": "timeout",
        "name": "⏱️ Global Timeout",
        "description": "Enter the time in ms that you're willing to wait for results before your scraper addons timeout. You can set it a bit higher if you have issues getting enough results or you want to make sure to get as many results as possible.",
        "type": "number",
        "required": false,
        "default": 5000
      },
      {
        "id": "header.sorting",
        "name": "↕️ Sorting Options",
        "description": "",
        "type": "alert",
        "intent": "info"
      },
      {
        "id": "header.sortingInfo",
        "name": "",
        "description": "Here you can modify the sort order if necessary. \n The default sort order is: \n *Cached/Uncached → SeaDex (for Anime) → Resolution → Quality → Stream Expressions → Stream Expression Score → Seeders (if Uncached/P2P) → Language → Bitrate*",
        "type": "alert",
        "intent": "info-basic"
      },
      {
        "id": "language",
        "name": "🚩️ Language Priority",
        "description": "This option can give priority to streams in your preferred languages by moving it up the sorting order. If you struggle to see your preferred languages in the results, even after adding it to the **Preferred Languages** list, try increasing the priority here. May rank lower-quality streams higher if your preferred languages are uncommon among the results, so use with caution.",
        "type": "select",
        "required": false,
        "default": "default",
        "options": [
          {
            "value": "default",
            "label": "Default Sort Order"
          },
          {
            "value": "medium",
            "label": "Move Up After Resolution & Quality"
          },
          {
            "value": "high",
            "label": "Move Up First in Sort Order"
          }
        ]
      },
      {
        "__if": "!services",
        "id": "seeders",
        "name": "🌱 Seeders Priority",
        "description": "Change this if you want highest seeders to be prioritized more on the sorting order, even if they have lower Resolution/Quality/SEL Scores. In most cases, low seeders will have already been filtered out by the internal filtering (SEL).",
        "type": "select",
        "required": false,
        "default": "default",
        "options": [
          {
            "value": "default",
            "label": "Default Sort Order"
          },
          {
            "value": "medium",
            "label": "Move Up After Resolution & Quality"
          },
          {
            "value": "high",
            "label": "Move Up First in Sort Order"
          }
        ]
      },
      {
        "id": "credits",
        "name": "Credits",
        "description": "",
        "type": "socials",
        "socials": [
          {
            "id": "website",
            "url": "https://luckynumb3rs.github.io/stremio-perfect-setup"
          },
          {
            "id": "github",
            "url": "https://github.com/luckynumb3rs/stremio-perfect-setup"
          },
          {
            "id": "ko-fi",
            "url": "https://ko-fi.com/luckynumb3rs"
          }
        ]
      }
	  ]
  },
  "config": {
    "addonName": "AIOStreams",
    "addonLogo": "https://raw.githubusercontent.com/luckynumb3rs/stremio-perfect-setup/refs/heads/main/docs/assets/images/sps-aiostreams.svg",
    "services": [
      {
        "id": "torbox",
        "enabled": false,
        "credentials": {}
      }
    ],
    "addonCategoryColors": {
      "Anime": "orange",
      "HTTP": "emerald"
    },
    "presets": [
      {
        "__if": "inputs.anime",
        "category": "Anime",
        "type": "seadex",
        "instanceId": "sdx",
        "enabled": true,
        "options": {
          "name": "SeaDex",
          "timeout": "{{inputs.timeout}}",
          "mediaTypes": [
            "anime"
          ]
        }
      },
      {
        "__if": "services and inputs.httpAddons != only",
        "type": "library",
        "instanceId": "lib",
        "enabled": true,
        "options": {
          "name": "Library",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "mediaTypes": [],
          "showRefreshActions": [
            "catalog"
          ],
          "skipProcessing": false,
          "hideStreams": false,
          "useMultipleInstances": false
        }
      },
      {
        "__if": "services.torbox and inputs.httpAddons != only",
        "type": "torbox",
        "instanceId": "tbx",
        "enabled": true,
        "options": {
          "name": "TorBox",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "mediaTypes": []
        }
      },
      {
        "__if": "inputs.debridio and inputs.httpAddons != only",
        "type": "debridio",
        "instanceId": "deb",
        "enabled": true,
        "options": {
          "name": "Debridio",
          "timeout": "{{inputs.timeout}}",
          "debridioApiKey": "<template_placeholder>"
        }
      },
      {
        "__if": "inputs.httpAddons != only",
        "type": "torrentio",
        "instanceId": "tio",
        "enabled": true,
        "options": {
          "name": "Torrentio",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "providers": [],
          "useMultipleInstances": false
        }
      },
      {
        "__if": "inputs.httpAddons != only",
        "type": "meteor",
        "instanceId": "met",
        "enabled": true,
        "options": {
          "name": "Meteor",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "includeP2P": {
            "__switch": "services",
            "cases": {
              "": true
            },
            "default": false
          },
          "removeTrash": false,
          "useMultipleInstances": false,
          "mediaTypes": []
        }
      },
      {
        "__if": "inputs.httpAddons != only",
        "type": "comet",
        "instanceId": "com",
        "enabled": true,
        "options": {
          "name": "Comet",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "includeP2P": {
            "__switch": "services",
            "cases": {
              "": true
            },
            "default": false
          },
          "removeTrash": false,
          "mediaTypes": []
        }
      },
      {
        "__if": "inputs.httpAddons != only",
        "type": "stremthruTorz",
        "instanceId": "stz",
        "enabled": true,
        "options": {
          "name": "StremThru Torz",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "includeP2P": {
            "__switch": "services",
            "cases": {
              "": true
            },
            "default": false
          },
          "useMultipleInstances": false,
          "mediaTypes": []
        }
      },
      {
        "__if": "inputs.httpAddons != only",
        "type": "mediafusion",
        "instanceId": "mdf",
        "enabled": true,
        "options": {
          "name": "MediaFusion",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "useCachedResultsOnly": true,
          "enableWatchlistCatalogs": false,
          "downloadViaBrowser": false,
          "contributorStreams": false,
          "certificationLevelsFilter": [],
          "nudityFilter": [],
          "mediaTypes": []
        }
      },
      {
        "__if": "services and inputs.httpAddons != only",
        "type": "knaben",
        "instanceId": "kna",
        "enabled": true,
        "options": {
          "name": "Knaben",
          "timeout": "{{inputs.timeout}}",
          "mediaTypes": [],
          "useMultipleInstances": false
        }
      },
      {
        "__if": "inputs.httpAddons != only",
        "type": "peerflix",
        "instanceId": "pfl",
        "enabled": true,
        "options": {
          "name": "Peerflix",
          "timeout": "{{inputs.timeout}}",
          "resources": [
            "stream"
          ],
          "mediaTypes": [],
          "useMultipleInstances": false,
          "showTorrentLinks": {
            "__switch": "services",
            "cases": {
              "": true
            },
            "default": false
          }
        }
      },
      {
        "__if": "inputs.anime and inputs.httpAddons != only",
        "category": "Anime",
