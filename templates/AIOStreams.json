{
  "metadata": {
    "id": "stremio.perfect.setup",
    "name": "Stremio Perfect Setup",
    "description": "This template is best combined with [this](https://luckynumb3rs.github.io/stremio-perfect-setup) guide. It includes options for **Debrid**, **P2P** (torrents), and **HTTP** alternatives, and it's built around a full and ready-to-go clean setup with multiple reliable scrapers for redundancy and sensible sorting and filtering. A lot of credit goes to **Tamtaro** for the template base, recommended filters, sort orders, and SELs as described on [this](https://github.com/Tam-Taro/SEL-Filtering-and-Sorting) GitHub repo.",
    "source": "external",
    "author": "Lucky Numb3rs",
    "version": "1.2.2",
    "category": "Full",
    "serviceRequired": false,
    "inputs": [
      {
        "__if": "!services",
        "id": "header.p2p",
        "name": "",
        "description": "🧲 No services selected, proceeding with **P2P** setup.",
        "type": "alert",
        "intent": "warning"
      },
      {
        "id": "formatterChoice",
        "name": "🖋️ Formatter Style",
        "description": "Choose the formatting of the stream information view. **Flat Monochrome Icons** has a cleaner look based on minimalistic white icons. **Colorful Icons** contains a colored version with more graphical icons. **None** retains your existing formatter (no changes will be made to the formatter, but other filters and settings will still be imported).",
        "type": "select",
        "required": false,
        "default": "flat",
        "options": [
          {
            "value": "flat",
            "label": "▶︎ Flat Monochrome Icons (Default)"
          },
          {
            "value": "color",
            "label": "🎬 Colorful Icons"
          },
          {
            "value": "retain",
            "label": "None (Keep Your Current)"
          }
        ]
      },
      {
        "id": "header.languages",
        "name": "🗣️ Language Options",
        "description": "",
        "type": "alert",
        "intent": "info"
      },
      {
        "id": "languages",
        "name": "🔊 Preferred Languages",
        "description": "Select your preferred stream languages that you want to be sorted first when the streaming options are shown. *Original, Dual Audio, Multi, Dubbed, and Unknown* are automatically appended after your selections. Fine-tune the full order in **Filters → Language** after import if you want.",
        "type": "multi-select",
        "required": false,
        "default": [
          "English"
        ],
        "options": [
          { "value": "Arabic", "label": "🇸🇦 Arabic" },
          { "value": "Bengali", "label": "🇧🇩 Bengali" },
          { "value": "Bulgarian", "label": "🇧🇬 Bulgarian" },
          { "value": "Chinese", "label": "🇨🇳 Chinese" },
          { "value": "Croatian", "label": "🇭🇷 Croatian" },
          { "value": "Czech", "label": "🇨🇿 Czech" },
          { "value": "Danish", "label": "🇩🇰 Danish" },
          { "value": "Dutch", "label": "🇳🇱 Dutch" },
          { "value": "English", "label": "🇬🇧 English" },
          { "value": "Estonian", "label": "🇪🇪 Estonian" },
          { "value": "Finnish", "label": "🇫🇮 Finnish" },
          { "value": "French", "label": "🇫🇷 French" },
          { "value": "German", "label": "🇩🇪 German" },
          { "value": "Greek", "label": "🇬🇷 Greek" },
          { "value": "Gujarati", "label": "🇮🇳 Gujarati" },
          { "value": "Hebrew", "label": "🇮🇱 Hebrew" },
          { "value": "Hindi", "label": "🇮🇳 Hindi" },
          { "value": "Hungarian", "label": "🇭🇺 Hungarian" },
          { "value": "Indonesian", "label": "🇮🇩 Indonesian" },
          { "value": "Italian", "label": "🇮🇹 Italian" },
          { "value": "Japanese", "label": "🇯🇵 Japanese" },
          { "value": "Kannada", "label": "🇮🇳 Kannada" },
          { "value": "Korean", "label": "🇰🇷 Korean" },
          { "value": "Latino", "label": "🇲🇽 Latino" },
          { "value": "Latvian", "label": "🇱🇻 Latvian" },
          { "value": "Lithuanian", "label": "🇱🇹 Lithuanian" },
          { "value": "Malayalam", "label": "🇮🇳 Malayalam" },
          { "value": "Malay", "label": "🇲🇾 Malay" },
          { "value": "Marathi", "label": "🇮🇳 Marathi" },
          { "value": "Norwegian", "label": "🇳🇴 Norwegian" },
          { "value": "Persian", "label": "🇮🇷 Persian" },
          { "value": "Polish", "label": "🇵🇱 Polish" },
          { "value": "Portuguese", "label": "🇵🇹 Portuguese" },
          { "value": "Punjabi", "label": "🇮🇳 Punjabi" },
          { "value": "Romanian", "label": "🇷🇴 Romanian" },
          { "value": "Russian", "label": "🇷🇺 Russian" },
          { "value": "Serbian", "label": "🇷🇸 Serbian" },
          { "value": "Slovak", "label": "🇸🇰 Slovak" },
          { "value": "Slovenian", "label": "🇸🇮 Slovenian" },
