{
  "metadata": {
    "id": "stremio.perfect.setup",
    "name": "Stremio Perfect Setup",
    "description": "This template is best combined with [this](https://luckynumb3rs.github.io/stremio-perfect-setup) guide. It includes options for **Debrid**, **P2P** (torrents), and **HTTP** alternatives, and it's built around a full and ready-to-go clean setup with multiple reliable scrapers for redundancy and sensible sorting and filtering. A lot of credit goes to **Tamtaro** for the template base, recommended filters, sort orders, and SELs as described on [this](https://github.com/Tam-Taro/SEL-Filtering-and-Sorting) GitHub repo.",
    "source": "external",
    "sourceUrl": "https://raw.githubusercontent.com/luckynumb3rs/stremio-perfect-setup/refs/heads/main/templates/AIOStreams.json",
    "changelogUrl": "https://raw.githubusercontent.com/luckynumb3rs/stremio-perfect-setup/refs/heads/main/CHANGELOG.md",
    "author": "Lucky Numb3rs",
    "version": "2.0.1",
    "category": "Full",
    "serviceRequired": false,
    "inputs": [
      {
        "__if": "!services",
        "id": "header.p2p",
        "name": "",
        "description": "No services selected, only **🧲 P2P / 🌐 HTTP** setup.",
        "type": "alert",
        "intent": "warning"
      },
      {
        "id": "formatterChoice",
        "name": "🖋️ Formatter Style",
        "description": "Choose the formatting of the stream information view (more details [here](https://luckynumb3rs.github.io/stremio-perfect-setup/guide/7-Additional-Stuff/#understanding-stream-information-view)): \n* **Flat Monochrome Icons** has a cleaner look based on minimalistic white icons. \n* **Colorful Icons** contains a colored version with more graphical icons. \n* **None** retains your existing formatter (no changes will be made to the formatter, but other filters and settings will still be imported).",
        "type": "select",
        "required": false,
        "default": "flat",
        "options": [
          {
            "value": "flat",
            "label": "▶︎ Flat Monochrome Icons"
          },
          {
            "value": "color",
            "label": "🎬 Colorful Icons"
          },
          {
            "value": "retain",
            "label": "🚫 None (Keep Your Current)"
          }
        ]
      },
      {
